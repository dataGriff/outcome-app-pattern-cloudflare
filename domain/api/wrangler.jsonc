{
  // The todo service — the one owner of the todo domain's behaviour.
  // Bindings are role-named (operational-store, events, relay, stream); the
  // honest implementation names live in the resource declarations below.
  "name": "todo-behaviour-service",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "dev": { "port": 8787 },
  "observability": { "enabled": true },
  // Custom domain on the domainapps.org zone. Auto-creates the DNS record + TLS
  // cert on deploy (requires the zone to be active). The *.workers.dev URL stays
  // live too; the in-Worker Access check (src/auth.ts) covers both hostnames.
  "routes": [{ "pattern": "todo-api.domainapps.org", "custom_domain": true }],
  "rules": [{ "type": "Text", "globs": ["**/*.yaml"], "fallthrough": true }],
  "d1_databases": [
    {
      "binding": "OPERATIONAL_STORE",
      "database_name": "todo",
      "database_id": "637bab81-7c5c-417a-97cd-5297f54780c9",
      "migrations_dir": "migrations"
    }
  ],
  "queues": {
    "producers": [{ "binding": "EVENTS", "queue": "todo-events" }]
  },
  "durable_objects": {
    "bindings": [
      { "name": "OUTBOX_RELAY", "class_name": "OutboxRelayDO" },
      { "name": "STREAM", "class_name": "StreamDO" }
    ]
  },
  // Free plan requires SQLite-backed Durable Object classes.
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["OutboxRelayDO", "StreamDO"] }],
  "vars": {
    "OUTBOX_RETENTION_SECONDS": "3600",
    // Abuse guard for the write endpoints (POST/PATCH/DELETE on todos). "on"
    // here so the deployed API enforces it; local dev + the Schemathesis run
    // override it to "off" (--var), and vitest sets "off" too, so the hermetic
    // gates aren't throttled. See src/ratelimit.ts and docs/deployment.
    "RATE_LIMIT": "on",
    // Cloudflare Access caller auth on every todo endpoint. Inert until
    // provisioned (like Turnstile): unset, every request acts as the fixed dev
    // identity. Set both to your team domain and this API's Access AUD tag to
    // enforce. Neither is secret. See src/auth.ts and docs/security.
    "ACCESS_TEAM_DOMAIN": "https://hungovercoders.cloudflareaccess.com",
    "ACCESS_AUD": ""
  },
  // Native Workers Rate Limiting (free, in-memory per-colo). Two limiters guard
  // the todo mutations: per-caller (client IP, or user sub over a service
  // binding) stops a single flooder; the global cap is the wallet ceiling
  // against distributed abuse driving R2 writes/storage. The simple limiter's
  // period must be 10 or 60 seconds.
  "unsafe": {
    "bindings": [
      { "name": "RL_PER_IP", "type": "ratelimit", "namespace_id": "1001", "simple": { "limit": 10, "period": 60 } },
      { "name": "RL_GLOBAL", "type": "ratelimit", "namespace_id": "1002", "simple": { "limit": 60, "period": 60 } }
    ]
  }
}
