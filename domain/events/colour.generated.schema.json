{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:outcome-app-pattern:event:colour.generated",
  "title": "ColourGeneratedEvent",
  "description": "CloudEvent published to the events role (the Cloudflare Queue 'colour-events') whenever the behaviour domain generates a colour. The authoritative copy of this schema also lives inline in domain/contracts/api/behaviour-service.asyncapi.yaml.",
  "type": "object",
  "required": ["id", "source", "specversion", "type", "data"],
  "properties": {
    "id": { "type": "string", "description": "Unique event identifier." },
    "source": {
      "type": "string",
      "description": "Event source URN.",
      "const": "urn:outcome-app-pattern:behaviour-service"
    },
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "const": "colour.generated" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["colour", "timestamp"],
      "properties": {
        "colour": { "type": "string", "enum": ["red", "amber", "green"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  }
}
