{
  // The agent experience: the one todo API as MCP tools. Reaches the
  // domain over a service binding (DOMAIN_API); McpAgent sessions live in a
  // SQLite-backed Durable Object (free-plan requirement).
  "name": "todo-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "dev": { "port": 8790 },
  "observability": { "enabled": true },
  // Custom domain on the domainapps.org zone — the hostname the Access app fronts
  // (Access as the OAuth provider for /mcp).
  "routes": [{ "pattern": "todo-agent.domainapps.org", "custom_domain": true }],
  // Keep the *.workers.dev URL live alongside the custom domain (declaring
  // routes otherwise disables it) — the CI verify job smokes workers.dev.
  "workers_dev": true,
  "services": [{ "binding": "DOMAIN_API", "service": "todo-behaviour-service" }],
  "durable_objects": {
    "bindings": [{ "name": "MCP_OBJECT", "class_name": "TodoAgent" }]
  },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["TodoAgent"] }],
  // Cloudflare Access identity for the MCP endpoint. Front /mcp with an Access
  // app (Access as the OAuth provider for MCP clients), then set both to gate
  // it here. Inert until set. See docs/security.
  "vars": {
    "ACCESS_TEAM_DOMAIN": "https://hungovercoders.cloudflareaccess.com",
    "ACCESS_AUD": ""
  }
}
